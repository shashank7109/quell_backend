# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# PostgreSQL connection string
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://quell:quell@localhost:5432/quell

# JWT secret — use a long random string in production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-a-long-random-string

# Razorpay — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: https://your-app.vercel.app/auth/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Deployment — set these in Render's environment variable panel
# FRONTEND_URL: your Vercel deployment URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# CORS_ORIGINS: comma-separated list of allowed frontend origins
# Include your Vercel URL and any preview URLs you want to allow
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
